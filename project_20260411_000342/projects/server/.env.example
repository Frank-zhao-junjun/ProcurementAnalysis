PORT=3000
NODE_ENV=development
# 内网演示：允许 GET /api/auth/dev-token 自动签发 JWT，并在 CORS 中反射 localhost 任意端口
ALLOW_DEV_TOKEN=true
JWT_SECRET=replace-me
CORS_ORIGIN=http://localhost:5500
COZE_API_BASE_URL=https://api.coze.cn
COZE_API_TOKEN=replace-me
COZE_BOT_ID=replace-me
COZE_TIMEOUT_MS=10000
AI_PROXY_CACHE_TTL_MS=30000
AI_PROXY_BREAKER_FAILURE_THRESHOLD=5
AI_PROXY_BREAKER_RECOVERY_WINDOW_MS=30000
NON_PRODUCTION_ONLY=true
AI_PRIVACY_GATE_REQUIRED=true